+function defaultAttackDpsState() {
+  return {
+    damageSource: "current",
+    manualDamage: 100,
+    weaponDelaySource: "currentWeapon",
+    manualWeaponDelay: 300,
+    equipmentBuffDelaySource: "auto",
+    equipmentBuffDelay: 0,
+    attackDelayBuff: 0,
+    stDelayBonus: -10,
+    manualAttackBonus: true,
+    criticalCancel: true,
